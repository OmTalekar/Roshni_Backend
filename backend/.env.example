# System
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# FastAPI
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./roshni.db
# DATABASE_URL=postgresql://user:password@localhost/roshni

# Algorand
ALGORAND_NETWORK=testnet
ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_ADMIN_MNEMONIC=your_25_word_mnemonic_here
SUN_ASA_ID=your_asa_id_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# DISCOM Config
DISCOM_FIXED_CHARGE=100.0
DISCOM_ADMIN_FEE_PERCENT=2.0
DISCOM_EXPORT_RATE=8.0
DISCOM_GRID_RATE=12.0

# Solar metrics
SOLAR_EXPORT_RATE=10.0
SOLAR_POOL_RATE=9.0

# IoT
IOT_AUTH_TOKEN=iot_secret_token_12345